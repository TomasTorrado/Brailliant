# Copy to .env and adjust for your setup. All have sensible defaults if unset.

# Serial port the ESP32 is connected to.
BRAILLE_SERIAL_PORT=/dev/ttyUSB0

# Must match Serial.begin(...) in firmware/esp32_braille.ino
BRAILLE_BAUD_RATE=9600

# Seconds to pause between characters / words while streaming, so the
# solenoids, frontend highlight, and speech readout stay in sync.
BRAILLE_CHAR_DELAY=0.4
BRAILLE_WORD_DELAY=0.6
